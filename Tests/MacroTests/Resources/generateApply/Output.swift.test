extension MyState {
  func with(
    name: String? = nil,
    count: Int? = nil
  ) -> Self {
    Self(name: name ?? self.name, count: count ?? self.count)
  }

  func apply(path: AnyKeyPath, value: Any) -> Self {
    typealias State = MyState

    return switch path {
      case \KTStateWrapper<State>.kt.name:
        with(name: value as? String)
      case \KTStateWrapper<State>.kt.count:
        with(count: value as? Int)
    default:
      fatalError("Unknown key path \(path)")
    }
  }
}
